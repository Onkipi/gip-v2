# App
APP_NAME=Real-Time Intelligence System
HOST=127.0.0.1
PORT=3000

# Socket
SOCKET_PATH=/socket.io
NEXT_PUBLIC_SOCKET_PATH=/socket.io
# Leave empty to use same origin
NEXT_PUBLIC_SOCKET_URL=

# Polling + simulation
INGEST_INTERVAL_MS=15000
INGEST_EVENT_CAP=72
MONTE_CARLO_ITERATIONS=1200
MAX_EVENTS=600
HISTORY_LIMIT=250
MACRO_REFRESH_MS=60000
RISK_ALERT_THRESHOLD=72
RISK_ALERT_COOLDOWN_MS=120000

# APIs (optional; system falls back to synthetic data when unavailable)
NEWS_API_KEY=
ALPHA_VANTAGE_API_KEY=
NEWS_LANGUAGE=en
NEWS_RSS_FEEDS=http://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://www.aljazeera.com/xml/rss/all.xml

# Source ingestion controls
ENABLE_DEFAULT_SOURCE_FEEDS=true
ENABLE_SYNTHETIC_FALLBACK=true
SOURCE_FETCH_TIMEOUT_MS=9000
SOURCE_MAX_AGE_HOURS=72
SOURCE_EMIT_CAP=36
SOURCE_PER_FEED_CAP=20
SOURCE_GOOGLE_LANGUAGE=en
SOURCE_GOOGLE_REGION=US
PREDICTION_MONTE_CARLO_RUNS=2400
PREDICTION_LOOKBACK_HOURS=72

# Core news + verification sources (Tier-1 trusted)
CORE_NEWS_FEEDS=Reuters|https://news.google.com/rss/search?q=site:reuters.com+geopolitics+OR+conflict+OR+military&hl=en-US&gl=US&ceid=US:en,Associated Press|https://news.google.com/rss/search?q=site:apnews.com+geopolitics+OR+war+OR+military&hl=en-US&gl=US&ceid=US:en,BBC News|http://feeds.bbci.co.uk/news/world/rss.xml,Al Jazeera|https://www.aljazeera.com/xml/rss/all.xml,The New York Times|https://rss.nytimes.com/services/xml/rss/nyt/World.xml

# OSINT + war intelligence
OSINT_FEEDS=Bellingcat|https://www.bellingcat.com/feed/,Oryx|https://www.oryxspioenkop.com/feeds/posts/default?alt=rss,Faytuks Network|https://news.google.com/rss/search?q=Faytuks+Network+war+updates&hl=en-US&gl=US&ceid=US:en,DeepStateMap.Live|https://news.google.com/rss/search?q=DeepStateMap+frontline+updates&hl=en-US&gl=US&ceid=US:en

# Flight + radar intelligence (replace with premium API bridges if available)
FLIGHT_FEEDS=Flightradar24|https://news.google.com/rss/search?q=Flightradar24+military+flight+tracking&hl=en-US&gl=US&ceid=US:en,RadarBox|https://news.google.com/rss/search?q=RadarBox+military+aircraft&hl=en-US&gl=US&ceid=US:en,ADS-B Exchange|https://news.google.com/rss/search?q=ADS-B+Exchange+military+flights&hl=en-US&gl=US&ceid=US:en

# Naval tracking layer
NAVAL_FEEDS=MarineTraffic|https://news.google.com/rss/search?q=MarineTraffic+naval+deployment&hl=en-US&gl=US&ceid=US:en,VesselFinder|https://news.google.com/rss/search?q=VesselFinder+warship+tanker+movement&hl=en-US&gl=US&ceid=US:en

# X/Twitter signal layer
SOCIAL_X_FEEDS=Aurora Intel|https://news.google.com/rss/search?q=%22Aurora+Intel%22+conflict+update&hl=en-US&gl=US&ceid=US:en,GeoConfirmed|https://news.google.com/rss/search?q=%22GeoConfirmed%22+geolocation&hl=en-US&gl=US&ceid=US:en,IntelSky|https://news.google.com/rss/search?q=%22IntelSky%22+war+update&hl=en-US&gl=US&ceid=US:en,Basha Report|https://news.google.com/rss/search?q=%22Basha+Report%22+geopolitics&hl=en-US&gl=US&ceid=US:en

# Reddit crowd intelligence
REDDIT_FEEDS=r/geopolitics|https://www.reddit.com/r/geopolitics/new/.rss,r/war|https://www.reddit.com/r/war/new/.rss,r/CombatFootage|https://www.reddit.com/r/CombatFootage/new/.rss,r/UkrainianConflict|https://www.reddit.com/r/UkrainianConflict/new/.rss

# YouTube OSINT channels
YOUTUBE_FEEDS=NEMICO Network|https://news.google.com/rss/search?q=NEMICO+Network+YouTube+war+dashboard&hl=en-US&gl=US&ceid=US:en,Intel Bird|https://news.google.com/rss/search?q=Intel+Bird+YouTube+military+aircraft&hl=en-US&gl=US&ceid=US:en,Truthdriven|https://news.google.com/rss/search?q=Truthdriven+YouTube+flight+data&hl=en-US&gl=US&ceid=US:en,Denys Davydov|https://news.google.com/rss/search?q=Denys+Davydov+YouTube+war+update&hl=en-US&gl=US&ceid=US:en

# Satellite + map intelligence
SATELLITE_FEEDS=Maxar Technologies|https://news.google.com/rss/search?q=Maxar+satellite+imagery+military&hl=en-US&gl=US&ceid=US:en,Planet Labs|https://news.google.com/rss/search?q=Planet+Labs+satellite+defense+activity&hl=en-US&gl=US&ceid=US:en,Google Earth|https://news.google.com/rss/search?q=Google+Earth+conflict+mapping&hl=en-US&gl=US&ceid=US:en

# Optional JSON event bridges for premium platforms (format: Name|URL,Name2|URL)
# Example adapters can bridge Flightradar24/RadarBox/ADS-B/MarineTraffic APIs into normalized JSON arrays
CUSTOM_SIGNAL_JSON_FEEDS=

# GDELT global event intelligence (open source API)
ENABLE_GDELT=true
GDELT_QUERY=geopolitics OR conflict OR military OR sanctions OR airspace OR naval OR drone OR missile OR border
GDELT_MAX_RECORDS=40

# Redis (optional; if empty the system uses in-process memory mode)
REDIS_URL=redis://127.0.0.1:6379
REDIS_CHANNEL=intel:stream
REDIS_HISTORY_KEY=intel:events
